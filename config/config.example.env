# ═══════════════════════════════════════════════════
# AI Issue Solver — Konfiguration
# ═══════════════════════════════════════════════════
#
# 1. Diese Datei kopieren:  cp config.example.env config/.env
# 2. Werte eintragen
# 3. NIEMALS die .env committen! (steht in .gitignore)
# ═══════════════════════════════════════════════════


# ── GitHub ───────────────────────────────────────────
# Dein GitHub Personal Access Token
# Erstellen: https://github.com/settings/tokens/new
# Benötigte Scopes: repo, read:user, workflow
GITHUB_TOKEN=ghp_DEIN_TOKEN_HIER

# Dein GitHub Username
GITHUB_USER=SaJaToGu


# ── Anthropic Claude ─────────────────────────────────
# API-Key von: https://console.anthropic.com/
# Nur nötig wenn --model claude verwendet wird
ANTHROPIC_API_KEY=sk-ant-DEIN_KEY_HIER


# ── OpenAI ───────────────────────────────────────────
# API-Key von: https://platform.openai.com/api-keys
# Nur nötig wenn --model openai verwendet wird
OPENAI_API_KEY=sk-DEIN_KEY_HIER


# ── OpenRouter ────────────────────────────────────────
# API-Key von: https://openrouter.ai/keys
# Nur nötig wenn --model openrouter verwendet wird
# OpenRouter ermöglicht Zugriff auf multiple Modelle über eine API:
# - openrouter/openai/gpt-4o-mini (Standard im Solver)
# - openrouter/openai/gpt-4o
# - openrouter/anthropic/claude-3-haiku, openrouter/anthropic/claude-3-sonnet
# - openrouter/mistralai/mistral-7b-instruct, openrouter/mistralai/mixtral-8x7b-instruct
# - openrouter/google/gemini-flash-1.5, openrouter/google/gemini-pro-1.5
# Vollständige Liste: https://openrouter.ai/models
OPENROUTER_API_KEY=sk-or-DEIN_KEY_HIER


# ── Mistral AI / Mistral Vibe / Magistral ───────────
# API-Key von: https://console.mistral.ai/
# Nur nötig wenn --model mistral-vibe oder --model mistral verwendet wird
# Mistral Vibe CLI: curl -LsSf https://mistral.ai/vibe/install.sh | bash
# Alternativ: uv tool install mistral-vibe oder pip install mistral-vibe
# Standard-Modell im Solver: magistral-medium-2509
# Legacy-/Kosten-Alternative, falls im Account noch verfügbar: magistral-small-2509
# Aktuelle offene Small-Alternative ausserhalb Magistral: mistral-small-2603
MISTRAL_API_KEY=DEIN_MISTRAL_KEY_HIER


# ── OpenCode CLI ───────────────────────────────────
# Nur nötig wenn --model opencode verwendet wird.
# Installation: curl -fsSL https://opencode.ai/install | bash
# OpenCode verwaltet Provider/API-Keys selbst, z.B. per:
#   opencode auth login
# Optional kann ein konkretes Provider-Modell mit --model-name gesetzt werden,
# z.B. --model-name mistral/mistral-small-2603


# ── Ollama (lokal) ───────────────────────────────────
# Nur nötig wenn --model ollama verwendet wird
# Standard: http://localhost:11434
# Für Remote-Raspberry-Pi: http://192.168.1.XXX:11434
OLLAMA_HOST=http://localhost:11434

# Standard-Modell für Ollama
# Empfehlungen:
#   Raspberry Pi 4 (4GB): llama3.2:3b
#   Raspberry Pi 5 (8GB): llama3.2:7b oder deepseek-coder:6.7b
#   PC/Mac:               deepseek-coder:6.7b oder codellama:13b
OLLAMA_MODEL=deepseek-coder:6.7b
